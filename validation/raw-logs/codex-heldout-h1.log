"""顧客イベントの日次バッチ処理。

cron で深夜に実行される。データ量が増える月末にメモリ不足で落ちるとの報告あり。
出力の daily_summary.json は翌朝のダッシュボード集計が読み込む。
"""

import csv
import json

INPUT_PATH = "/data/events/daily_events.csv"
OUTPUT_PATH = "/data/events/daily_summary.json"
BATCH_SIZE = 100


def transform(rows: list[dict]) -> list[dict]:
    summaries = []
    for row in rows:
        summaries.append(
            {
                "customer_id": row["customer_id"],
                "event": row["event_type"].lower().strip(),
                "value": float(row["value"] or 0),
            }
        )
    return summaries


def write_summaries(output_file, summaries: list[dict], is_first: bool) -> bool:
    for summary in summaries:
        if not is_first:
            output_file.write(", ")
        json.dump(summary, output_file, ensure_ascii=False)
        is_first = False
    return is_first


def run() -> None:
    batch = []
    with open(INPUT_PATH, newline="", encoding="utf-8") as f, open(
        OUTPUT_PATH, "w", encoding="utf-8"
    ) as output_file:
        reader = csv.DictReader(f)
        output_file.write("[")
        is_first = True
        for row in reader:
            batch.append(row)
            if len(batch) >= BATCH_SIZE:
                is_first = write_summaries(output_file, transform(batch), is_first)
                batch = []
        if batch:
            write_summaries(output_file, transform(batch), is_first)
        output_file.write("]")


if __name__ == "__main__":
    run()

