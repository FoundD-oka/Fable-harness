"""日次売上レポートをCSVに書き出すスクリプト。

cron で毎晩23時に実行される。
"""

import argparse
import csv
from datetime import date
from pathlib import Path

from db import fetch_daily_sales  # 社内DBユーティリティ

OUTPUT_PATH = Path("reports/daily_report.csv")


def build_output_path(*, dated_output: bool, report_date: date | None = None) -> Path:
    if not dated_output:
        return OUTPUT_PATH

    report_date = report_date or date.today()
    return OUTPUT_PATH.with_name(
        f"{OUTPUT_PATH.stem}_{report_date.strftime('%Y%m%d')}{OUTPUT_PATH.suffix}"
    )


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--dated-output",
        action="store_true",
        help="出力ファイル名に実行日を YYYYMMDD 形式で付与する",
    )
    return parser.parse_args()


def export(output_path: Path = OUTPUT_PATH) -> None:
    rows = fetch_daily_sales()
    with open(output_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow(["customer_id", "product", "amount"])
        for row in rows:
            writer.writerow([row["customer_id"], row["product"], row["amount"]])


if __name__ == "__main__":
    args = parse_args()
    export(build_output_path(dated_output=args.dated_output))

