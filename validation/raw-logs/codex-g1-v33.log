 succeeded in 0ms:
"""日次売上レポートをCSVに書き出すスクリプト。

cron で毎晩23時に実行される。
"""

import argparse
import csv
from datetime import date, datetime
from pathlib import Path
from typing import Optional

from db import fetch_daily_sales  # 社内DBユーティリティ

OUTPUT_PATH = "reports/daily_report.csv"


def build_output_path(*, dated_output: bool, report_date: Optional[date] = None) -> str:
    if not dated_output and report_date is None:
        return OUTPUT_PATH

    report_date = report_date or date.today()
    output_path = Path(OUTPUT_PATH)
    return str(
        output_path.with_name(
            f"{output_path.stem}_{report_date.strftime('%Y%m%d')}{output_path.suffix}"
        )
    )


def parse_output_date(value: str) -> date:
    try:
        return datetime.strptime(value, "%Y%m%d").date()
    except ValueError as exc:
        raise argparse.ArgumentTypeError(
            "--output-date には YYYYMMDD 形式の日付を指定してください"
        ) from exc


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--dated-output",
        action="store_true",
        help="出力ファイル名に実行日を YYYYMMDD 形式で付与する",
    )
    parser.add_argument(
        "--output-date",
        type=parse_output_date,
        help="出力ファイル名に付与する日付を YYYYMMDD 形式で指定する",
    )
    return parser.parse_args()


def export(output_path: Optional[str] = None) -> None:
    output_path = output_path or OUTPUT_PATH
    rows = fetch_daily_sales()
    with open(output_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow(["customer_id", "product", "amount"])
        for row in rows:
            writer.writerow([row["customer_id"], row["product"], row["amount"]])


if __name__ == "__main__":
    args = parse_args()
    export(
        build_output_path(
            dated_output=args.dated_output,
            report_date=args.output_date,
        )
    )

