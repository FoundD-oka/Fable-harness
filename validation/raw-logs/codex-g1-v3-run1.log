"""日次売上レポートをCSVに書き出すスクリプト。

cron で毎晩23時に実行される。
"""

import csv
from datetime import date
from pathlib import Path
from typing import Optional

from db import fetch_daily_sales  # 社内DBユーティリティ

OUTPUT_DIR = Path("reports")


def build_output_path(report_date: Optional[date] = None) -> Path:
    report_date = report_date or date.today()
    return OUTPUT_DIR / f"daily_report_{report_date:%Y%m%d}.csv"


def export(report_date: Optional[date] = None) -> None:
    rows = fetch_daily_sales()
    output_path = build_output_path(report_date)
    with open(output_path, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow(["customer_id", "product", "amount"])
        for row in rows:
            writer.writerow([row["customer_id"], row["product"], row["amount"]])


if __name__ == "__main__":
    export()

